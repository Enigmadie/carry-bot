# Copy to .env and adjust. The service also runs with these defaults as-is.

NATS_URL=nats://localhost:4222

# Trading pair (neutral symbol; the quote suffix is stripped). The bot holds spot
# long + perp short, so the coin must be listed on BOTH spot and perp on the venue.
# Hyperliquid keys perps by coin and wraps spot BTC/ETH as UBTC/UETH (aliased
# internally). HL testnet has no BTC spot — pick a coin listed on both there, e.g.
# SYMBOL=HYPEUSDC.
SYMBOL=BTCUSDT

# --- market-data ---
# Hyperliquid public WebSocket + /info. Both feeds (prices, funding) ride one
# socket. HL_MAINNET picks the default WS/REST host and is shared with
# order-service below; HL_WS / HL_API override the host explicitly.
# HL_WS=wss://api.hyperliquid.xyz/ws  # default follows HL_MAINNET (testnet otherwise)

# --- order-service ---
# Provider behind the exchange interface: mock (default, keyless) | bybit | hyperliquid.
EXCHANGE=mock
# Mock only: force this leg's category (spot|linear) to fail, to exercise rollback.
# MOCK_FAIL_LEG=
# Bybit (EXCHANGE=bybit only) testnet API key: Read-Write, Trade only (no Withdraw).
BYBIT_API_KEY=
BYBIT_API_SECRET=
# REST host. Testnet by default; real trading: https://api.bybit.com
BYBIT_REST=https://api-testnet.bybit.com

# Hyperliquid (EXCHANGE=hyperliquid only). HL_PRIVATE_KEY is the AGENT-wallet key:
# it signs L1 actions (trade) but cannot withdraw, so it is safe on the node — never
# put the master key here. Create + authorize the agent on the HL app's API page.
# HL_MAINNET selects the signing domain AND the default host: an empty HL_API
# follows HL_MAINNET (testnet when false). If you set HL_API explicitly it must
# match HL_MAINNET, or every signature is silently rejected.
HL_PRIVATE_KEY=
# HL_API=https://api.hyperliquid.xyz   # optional; default follows HL_MAINNET
# HL_MAINNET=true
# Optional vault/sub-account to trade as, instead of the key's own account.
# HL_VAULT=
# Master account funding/fill queries target. Required with a separate agent wallet
# (the signer's address differs from the master), else funding comes back empty.
# HL_ACCOUNT=
# Perp leverage set to cross margin at startup so the spot USDC backs the short
# (HL defaults to isolated 10x, which can block the close). 0 leaves the account
# as-is. Low is intentional — collateral, not size, is what unblocks closing.
# HL_LEVERAGE=3
# Base-coin amount per leg (intents carry no size).
ORDER_QTY=0.001
# How often to poll the exchange for funding settlements (Go duration). 0 disables.
FUNDING_POLL=30s

# --- portfolio-service ---
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5555/carrybot

# --- strategy-service ---
# Smoke only: force-open the position on any funding rate.
# ENTRY_THRESHOLD=-1

# --- metrics (all services) ---
# Prometheus /metrics listen address. Distinct default ports so the four
# services don't collide when run together via `make` on one host; in containers
# each is scraped by name on the infra network, so the value can stay uniform.
#   market-data :2112  strategy :2113  order :2114  portfolio :2115
# METRICS_ADDR=:2112
