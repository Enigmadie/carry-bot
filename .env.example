# Copy to .env and adjust. The service also runs with these defaults as-is.

NATS_URL=nats://localhost:4222

# Bybit public WebSocket. Testnet by default; for real prices use:
#   wss://stream.bybit.com/v5/public/linear
#   wss://stream.bybit.com/v5/public/spot
BYBIT_WS_PUBLIC_LINEAR=wss://stream-testnet.bybit.com/v5/public/linear
BYBIT_WS_PUBLIC_SPOT=wss://stream-testnet.bybit.com/v5/public/spot

SYMBOL=BTCUSDT

# Optional source IP to bind Bybit REST+WS sockets to, so they egress on a
# chosen interface (the rest of the process keeps the default route). Empty =
# default route.
# BYBIT_BIND_ADDR=

# --- order-service ---
# Bybit testnet API key: Read-Write, permission Trade only (no Withdraw).
BYBIT_API_KEY=
BYBIT_API_SECRET=
# REST host. Testnet by default; real trading: https://api.bybit.com
BYBIT_REST=https://api-testnet.bybit.com
# Base-coin amount per leg (intents carry no size).
ORDER_QTY=0.001

# --- strategy-service ---
# Smoke only: force-open the position on any funding rate.
# ENTRY_THRESHOLD=-1
